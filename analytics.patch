+  { icon: ListChecks, title: "100 Tasks Completed", earned: true },
+  { icon: Mic, title: "10 Interviews", earned: true },
+  { icon: FileText, title: "Resume Expert", earned: true },
+  { icon: Target, title: "Placement Ready", earned: false },
