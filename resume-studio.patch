+  { icon: Percent, label: "ATS 91%" },
+  { icon: CheckCircle2, label: "Grammar ✓" },
+  { icon: CheckCircle2, label: "Formatting ✓" },
+  { icon: Sparkles, label: "AI Optimized" },
