@@ -0,0 +1,201 @@
+import { apiFetch } from "@/lib/api";
+
+// --- Types (mirror backend/app/schemas/profile.py + profile_sections.py exactly) ---
+
+export interface Profile {
+  id: string;
+  user_id: string;
+  email: string | null;
+  full_name: string | null;
+  headline: string | null;
+  college: string | null;
+  degree: string | null;
+  graduation_year: number | null;
+  location: string | null;
+  bio: string | null;
+  phone: string | null;
+  target_role: string | null;
+  dream_companies: string[] | null;
+  expected_salary: string | null;
+  preferred_location: string | null;
+  preferred_work_mode: string | null;
+  career_interests: string[] | null;
+  linkedin_url: string | null;
+  github_url: string | null;
+  portfolio_url: string | null;
+  created_at: string;
+  updated_at: string;
+}
+
+export type ProfileUpdateInput = Partial<
+  Omit<Profile, "id" | "user_id" | "email" | "created_at" | "updated_at">
+>;
+
+export interface Education {
+  id: string;
+  college: string;
+  degree: string;
+  duration: string | null;
+  cgpa: string | null;
+  coursework: string | null;
+  achievement: string | null;
+  order_index: number;
+}
+export type EducationInput = Omit<Education, "id">;
+
+export interface Skill {
+  id: string;
+  category: string;
+  name: string;
+  level: number;
+  proficiency_label: string;
+  order_index: number;
+}
+export type SkillInput = Omit<Skill, "id">;
+
+export interface Project {
+  id: string;
+  name: string;
+  description: string | null;
+  tech_stack: string[] | null;
+  github_url: string | null;
+  live_url: string | null;
+  status: string;
+  duration: string | null;
+  order_index: number;
+}
+export type ProjectInput = Omit<Project, "id">;
+
+export interface Experience {
+  id: string;
+  role: string;
+  organization: string;
+  duration: string | null;
+  description: string | null;
+  type: string;
+  order_index: number;
+}
+export type ExperienceInput = Omit<Experience, "id">;
+
+export interface Certification {
+  id: string;
+  name: string;
+  platform: string | null;
+  issued_date: string | null;
+  credential_id: string | null;
+  certificate_url: string | null;
+  order_index: number;
+}
+export type CertificationInput = Omit<Certification, "id">;
+
+export interface Achievement {
+  id: string;
+  type: string;
+  label: string;
+  value: number;
+  icon_key: string;
+  order_index: number;
+}
+export type AchievementInput = Omit<Achievement, "id">;
+
+export interface SocialLink {
+  id: string;
+  platform: string;
+  username: string | null;
+  url: string | null;
+  is_connected: boolean;
+}
+export type SocialLinkInput = Omit<SocialLink, "id">;
+
+export interface CareerSnapshot {
+  profile_completion: number;
+  resume_score: number | null;
+  projects_count: number;
+  certificates_count: number;
+  skills_count: number;
+  placement_readiness: number | null;
+}
+
+export interface ProfileInsights {
+  insights: string[];
+}
+
+export interface ActivityEvent {
+  title: string;
+  event_type: string;
+  occurred_at: string;
+}
+
+export interface AccountStatistics {
+  profile_views: number;
+  resume_downloads: number;
+  portfolio_visits: number;
+  interview_invitations: number;
+  job_matches: number;
+  applications: number;
+}
+
+export type AccountStatMetric =
+  | "profile_views"
+  | "resume_downloads"
+  | "portfolio_visits"
+  | "interview_invitations";
+
+// --- Core profile ---
+
+export function getProfile(): Promise<Profile> {
+  return apiFetch<Profile>("/api/v1/profile/me");
+}
+
+export function updateProfile(patch: ProfileUpdateInput): Promise<Profile> {
+  return apiFetch<Profile>("/api/v1/profile/me", {
+    method: "PUT",
+    body: JSON.stringify(patch),
+  });
+}
+
+// --- List sections (replace-all PUT) ---
+
+export const getEducation = () => apiFetch<Education[]>("/api/v1/profile/education");
+export const updateEducation = (items: EducationInput[]) =>
+  apiFetch<Education[]>("/api/v1/profile/education", { method: "PUT", body: JSON.stringify(items) });
+
+export const getSkills = () => apiFetch<Skill[]>("/api/v1/profile/skills");
+export const updateSkills = (items: SkillInput[]) =>
+  apiFetch<Skill[]>("/api/v1/profile/skills", { method: "PUT", body: JSON.stringify(items) });
+
+export const getProjects = () => apiFetch<Project[]>("/api/v1/profile/projects");
+export const updateProjects = (items: ProjectInput[]) =>
+  apiFetch<Project[]>("/api/v1/profile/projects", { method: "PUT", body: JSON.stringify(items) });
+
+export const getExperience = () => apiFetch<Experience[]>("/api/v1/profile/experience");
+export const updateExperience = (items: ExperienceInput[]) =>
+  apiFetch<Experience[]>("/api/v1/profile/experience", { method: "PUT", body: JSON.stringify(items) });
+
+export const getCertifications = () => apiFetch<Certification[]>("/api/v1/profile/certifications");
+export const updateCertifications = (items: CertificationInput[]) =>
+  apiFetch<Certification[]>("/api/v1/profile/certifications", {
+    method: "PUT",
+    body: JSON.stringify(items),
+  });
+
+export const getAchievements = () => apiFetch<Achievement[]>("/api/v1/profile/achievements");
+export const updateAchievements = (items: AchievementInput[]) =>
+  apiFetch<Achievement[]>("/api/v1/profile/achievements", { method: "PUT", body: JSON.stringify(items) });
+
+export const getSocialLinks = () => apiFetch<SocialLink[]>("/api/v1/profile/social-links");
+export const updateSocialLinks = (items: SocialLinkInput[]) =>
+  apiFetch<SocialLink[]>("/api/v1/profile/social-links", { method: "PUT", body: JSON.stringify(items) });
+
+// --- Computed / read-only sections ---
+
+export const getCareerSnapshot = () => apiFetch<CareerSnapshot>("/api/v1/profile/snapshot");
+export const getProfileInsights = () => apiFetch<ProfileInsights>("/api/v1/profile/insights");
+export const getRecentActivity = () => apiFetch<ActivityEvent[]>("/api/v1/profile/activity");
+export const getAccountStatistics = () => apiFetch<AccountStatistics>("/api/v1/profile/stats");
+
+export const incrementAccountStat = (metric: AccountStatMetric) =>
+  apiFetch<AccountStatistics>("/api/v1/profile/stats/increment", {
+    method: "POST",
+    body: JSON.stringify({ metric }),
+  });
