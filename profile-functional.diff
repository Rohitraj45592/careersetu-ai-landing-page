+def _replace_all(db: Session, model, user_id: uuid.UUID, items: list, build_kwargs):
+    db.query(model).filter(model.user_id == user_id).delete()
+    rows = [model(user_id=user_id, **build_kwargs(item, index)) for index, item in enumerate(items)]
+    db.add_all(rows)
+    db.commit()
+    return db.scalars(
