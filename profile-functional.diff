@@ -0,0 +1,174 @@
+"""Schemas for every Profile sub-section besides the core Profile row itself."""
+
+import uuid
+from datetime import datetime
+
+from pydantic import BaseModel, ConfigDict
+
+
+# --- Education ----------------------------------------------------------
+class EducationBase(BaseModel):
+    college: str
+    degree: str
+    duration: str | None = None
+    cgpa: str | None = None
+    coursework: str | None = None
+    achievement: str | None = None
+    order_index: int = 0
+
+
+class EducationCreate(EducationBase):
+    pass
+
+
+class EducationRead(EducationBase):
+    model_config = ConfigDict(from_attributes=True)
+    id: uuid.UUID
+
+
+# --- Skills ---------------------------------------------------------------
+class SkillBase(BaseModel):
+    category: str
+    name: str
+    level: int
+    proficiency_label: str
+    order_index: int = 0
+
+
+class SkillCreate(SkillBase):
+    pass
+
+
+class SkillRead(SkillBase):
+    model_config = ConfigDict(from_attributes=True)
+    id: uuid.UUID
+
+
+# --- Projects ---------------------------------------------------------------
+class ProjectBase(BaseModel):
+    name: str
+    description: str | None = None
+    tech_stack: list[str] | None = None
+    github_url: str | None = None
+    live_url: str | None = None
+    status: str = "Completed"
+    duration: str | None = None
+    order_index: int = 0
+
+
+class ProjectCreate(ProjectBase):
+    pass
+
+
+class ProjectRead(ProjectBase):
+    model_config = ConfigDict(from_attributes=True)
+    id: uuid.UUID
+
+
+# --- Experience ---------------------------------------------------------------
+class ExperienceBase(BaseModel):
+    role: str
+    organization: str
+    duration: str | None = None
+    description: str | None = None
+    type: str = "Internship"
+    order_index: int = 0
+
+
+class ExperienceCreate(ExperienceBase):
+    pass
+
+
+class ExperienceRead(ExperienceBase):
+    model_config = ConfigDict(from_attributes=True)
+    id: uuid.UUID
+
+
+# --- Certifications ---------------------------------------------------------
+class CertificationBase(BaseModel):
+    name: str
+    platform: str | None = None
+    issued_date: str | None = None
+    credential_id: str | None = None
+    certificate_url: str | None = None
+    order_index: int = 0
+
+
+class CertificationCreate(CertificationBase):
+    pass
+
+
+class CertificationRead(CertificationBase):
+    model_config = ConfigDict(from_attributes=True)
+    id: uuid.UUID
+
+
+# --- Achievements ---------------------------------------------------------
+class AchievementBase(BaseModel):
+    type: str
+    label: str
+    value: int
+    icon_key: str
+    order_index: int = 0
+
+
+class AchievementCreate(AchievementBase):
+    pass
+
+
+class AchievementRead(AchievementBase):
+    model_config = ConfigDict(from_attributes=True)
+    id: uuid.UUID
+
+
+# --- Social links (leetcode/codeforces/hackerrank) -------------------------
+class SocialLinkBase(BaseModel):
+    platform: str
+    username: str | None = None
+    url: str | None = None
+    is_connected: bool = False
+
+
+class SocialLinkUpsert(SocialLinkBase):
+    pass
+
+
+class SocialLinkRead(SocialLinkBase):
+    model_config = ConfigDict(from_attributes=True)
+    id: uuid.UUID
+
+
+# --- Career Snapshot (computed, read-only) ----------------------------------
+class CareerSnapshotRead(BaseModel):
+    profile_completion: int
+    resume_score: int | None
+    projects_count: int
+    certificates_count: int
+    skills_count: int
+    placement_readiness: int | None
+
+
+# --- AI Profile Insights (computed, read-only) -------------------------------
+class ProfileInsightsRead(BaseModel):
+    insights: list[str]
+
+
+# --- Recent Activity (computed from other modules' tables, read-only) -------
+class ActivityEventRead(BaseModel):
+    title: str
+    event_type: str
+    occurred_at: datetime
+
+
+# --- Account Statistics -----------------------------------------------------
+class AccountStatisticsRead(BaseModel):
+    profile_views: int
+    resume_downloads: int
+    portfolio_visits: int
+    interview_invitations: int
+    job_matches: int
+    applications: int
+
+
+class AccountStatIncrement(BaseModel):
+    metric: str  # profile_views|resume_downloads|portfolio_visits|interview_invitations
diff --git a/backend/app/services/profile_service.py b/backend/app/services/profile_service.py
new file mode 100644
index 0000000..4647676
--- /dev/null
+++ b/backend/app/services/profile_service.py
@@ -0,0 +1,161 @@
+"""
+Everything here is read-only aggregation for the Profile page's
+computed sections (Career Snapshot, AI Insights, Recent Activity,
+Account Statistics). It queries other modules' tables (resumes,
+job_matches, interview_sessions, analytics_snapshots) directly via
+SQLAlchemy SELECTs - it never imports or calls their routers, and
+never writes to their tables. Those modules are untouched.
+"""
+
+import uuid
+
+from sqlalchemy import select
+from sqlalchemy.orm import Session
+
+from app.models.analytics import AnalyticsSnapshot
+from app.models.certification import Certification
+from app.models.interview import InterviewSession
+from app.models.job import JobMatch
+from app.models.profile import Profile
+from app.models.project import Project
+from app.models.resume import Resume, ResumeAnalysis
+from app.models.skill import Skill
+
+_PROFILE_COMPLETION_FIELDS = [
+    "full_name",
+    "headline",
+    "college",
+    "degree",
+    "graduation_year",
+    "location",
+    "bio",
+    "phone",
+    "target_role",
+    "linkedin_url",
+    "github_url",
+    "portfolio_url",
+]
+
+
+def compute_profile_completion(profile: Profile) -> int:
+    filled = sum(1 for field_name in _PROFILE_COMPLETION_FIELDS if getattr(profile, field_name))
+    return round((filled / len(_PROFILE_COMPLETION_FIELDS)) * 100)
+
+
+def get_career_snapshot(db: Session, user_id: uuid.UUID, profile: Profile) -> dict:
+    latest_analysis = db.scalar(
+        select(ResumeAnalysis)
+        .where(ResumeAnalysis.user_id == user_id)
+        .order_by(ResumeAnalysis.created_at.desc())
+    )
+    latest_snapshot = db.scalar(
+        select(AnalyticsSnapshot)
+        .where(AnalyticsSnapshot.user_id == user_id)
+        .order_by(AnalyticsSnapshot.snapshot_date.desc())
+    )
+    projects_count = len(db.scalars(select(Project).where(Project.user_id == user_id)).all())
+    certificates_count = len(db.scalars(select(Certification).where(Certification.user_id == user_id)).all())
+    skills_count = len(db.scalars(select(Skill).where(Skill.user_id == user_id)).all())
+
+    return {
+        "profile_completion": compute_profile_completion(profile),
+        "resume_score": latest_analysis.overall_score if latest_analysis else None,
+        "projects_count": projects_count,
+        "certificates_count": certificates_count,
+        "skills_count": skills_count,
+        "placement_readiness": latest_snapshot.placement_readiness if latest_snapshot else None,
+    }
+
+
+def generate_profile_insights(db: Session, user_id: uuid.UUID, profile: Profile) -> list[str]:
+    """
+    Deterministic, grounded in real data (not a live LLM call) - same
+    pattern as the other services/*.py placeholders. Swap the body for
+    a real model call later; keep returning list[str].
+    """
+    insights: list[str] = []
+
+    if not profile.linkedin_url:
+        insights.append("Complete your LinkedIn profile to improve recruiter visibility.")
+
+    project_count = len(db.scalars(select(Project).where(Project.user_id == user_id)).all())
+    if project_count < 4:
+        insights.append("Add one more backend project to balance your portfolio.")
+
+    if not profile.portfolio_url:
+        insights.append("Add a portfolio link — recruiters check it more than you'd expect.")
+
+    latest_resume = db.scalar(
+        select(Resume).where(Resume.user_id == user_id).order_by(Resume.created_at.desc())
+    )
+    if latest_resume is None:
+        insights.append("Upload your resume to unlock ATS scoring and tailored suggestions.")
+
+    if not any("aws" in (s.name or "").lower() or "cloud" in (s.name or "").lower() for s in
+               db.scalars(select(Skill).where(Skill.user_id == user_id)).all()):
+        insights.append("Earn a cloud certification to strengthen your profile.")
+
+    if not insights:
+        insights.append("Your profile looks strong — keep it updated as you finish new projects.")
+
+    return insights
+
+
+def get_recent_activity(db: Session, user_id: uuid.UUID, limit: int = 10) -> list[dict]:
+    events: list[dict] = []
+
+    for resume in db.scalars(
+        select(Resume).where(Resume.user_id == user_id).order_by(Resume.created_at.desc()).limit(5)
+    ):
+        events.append({"title": "Resume Updated", "event_type": "resume", "occurred_at": resume.created_at})
+
+    for project in db.scalars(
+        select(Project).where(Project.user_id == user_id).order_by(Project.created_at.desc()).limit(5)
+    ):
+        events.append(
+            {"title": f"Project Added — {project.name}", "event_type": "project", "occurred_at": project.created_at}
+        )
+
+    for cert in db.scalars(
+        select(Certification)
+        .where(Certification.user_id == user_id)
+        .order_by(Certification.created_at.desc())
+        .limit(5)
+    ):
+        events.append(
+            {
+                "title": f"Certificate Uploaded — {cert.name}",
+                "event_type": "certification",
+                "occurred_at": cert.created_at,
+            }
+        )
+
+    for session in db.scalars(
+        select(InterviewSession)
+        .where(InterviewSession.user_id == user_id, InterviewSession.status == "completed")
+        .order_by(InterviewSession.completed_at.desc())
+        .limit(5)
+    ):
+        events.append(
+            {
+                "title": f"Interview Completed — {session.interview_type.replace('_', ' ').title()}",
+                "event_type": "interview",
+                "occurred_at": session.completed_at,
+            }
+        )
+
+    for profile in db.scalars(
+        select(Profile).where(Profile.user_id == user_id).order_by(Profile.updated_at.desc()).limit(1)
+    ):
+        if profile.updated_at != profile.created_at:
+            events.append({"title": "Profile Updated", "event_type": "profile", "occurred_at": profile.updated_at})
+
+    events.sort(key=lambda e: e["occurred_at"], reverse=True)
+    return events[:limit]
+
+
+def get_job_hub_counts(db: Session, user_id: uuid.UUID) -> tuple[int, int]:
+    """(job_matches_count, applications_count) - read-only against Job Hub's own table."""
+    matches = db.scalars(select(JobMatch).where(JobMatch.user_id == user_id)).all()
+    applications = [m for m in matches if m.status != "suggested"]
+    return len(matches), len(applications)
