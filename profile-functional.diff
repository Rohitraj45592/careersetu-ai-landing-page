new file mode 100644
index 0000000..bac7608
--- /dev/null
+++ b/hooks/useProfile.ts
@@ -0,0 +1,199 @@
+"use client";
+
+import {
+  createElement,
+  createContext,
+  useCallback,
+  useContext,
+  useEffect,
+  useState,
+  type ReactNode,
+} from "react";
+
+import { ApiError } from "@/lib/api";
+import * as profileApi from "@/lib/profile";
+import type {
+  AccountStatistics,
+  Achievement,
+  ActivityEvent,
+  CareerSnapshot,
+  Certification,
+  Education,
+  Experience,
+  Profile,
+  ProfileInsights,
+  ProfileUpdateInput,
+  Project,
+  Skill,
+  SocialLink,
+} from "@/lib/profile";
+
+interface ProfileState {
+  profile: Profile | null;
+  education: Education[];
+  skills: Skill[];
+  projects: Project[];
+  experience: Experience[];
+  certifications: Certification[];
+  achievements: Achievement[];
+  socialLinks: SocialLink[];
+  snapshot: CareerSnapshot | null;
+  insights: ProfileInsights | null;
+  activity: ActivityEvent[];
+  stats: AccountStatistics | null;
+}
+
+interface ProfileContextValue extends ProfileState {
+  loading: boolean;
+  error: string | null;
+  saving: boolean;
+  saveSuccess: boolean;
+  isEditing: boolean;
+  setIsEditing: (value: boolean) => void;
+  refetch: () => void;
+  saveProfile: (patch: ProfileUpdateInput) => Promise<void>;
+}
+
+const ProfileContext = createContext<ProfileContextValue | null>(null);
+
+const emptyState: ProfileState = {
+  profile: null,
+  education: [],
+  skills: [],
+  projects: [],
+  experience: [],
+  certifications: [],
+  achievements: [],
+  socialLinks: [],
+  snapshot: null,
+  insights: null,
+  activity: [],
+  stats: null,
+};
+
+export function ProfileProvider({ children }: { children: ReactNode }) {
+  const [state, setState] = useState<ProfileState>(emptyState);
+  const [loading, setLoading] = useState(true);
+  const [error, setError] = useState<string | null>(null);
+  const [saving, setSaving] = useState(false);
+  const [saveSuccess, setSaveSuccess] = useState(false);
+  const [isEditing, setIsEditing] = useState(false);
+  const [refetchToken, setRefetchToken] = useState(0);
+
+  useEffect(() => {
+    let cancelled = false;
+
+    async function load() {
+      setLoading(true);
+      setError(null);
+
+      try {
+        const [
+          profile,
+          education,
+          skills,
+          projects,
+          experience,
+          certifications,
+          achievements,
+          socialLinks,
+          snapshot,
+          insights,
+          activity,
+          stats,
+        ] = await Promise.all([
+          profileApi.getProfile(),
+          profileApi.getEducation(),
+          profileApi.getSkills(),
+          profileApi.getProjects(),
+          profileApi.getExperience(),
+          profileApi.getCertifications(),
+          profileApi.getAchievements(),
+          profileApi.getSocialLinks(),
+          profileApi.getCareerSnapshot(),
+          profileApi.getProfileInsights(),
+          profileApi.getRecentActivity(),
+          profileApi.getAccountStatistics(),
+        ]);
+
+        if (cancelled) return;
+
+        setState({
+          profile,
+          education,
+          skills,
+          projects,
+          experience,
+          certifications,
+          achievements,
+          socialLinks,
+          snapshot,
+          insights,
+          activity,
+          stats,
+        });
+      } catch (err) {
+        if (cancelled) return;
+        setError(err instanceof ApiError ? err.message : "Couldn't load your profile. Please try again.");
+      } finally {
+        if (!cancelled) setLoading(false);
+      }
+    }
+
+    load();
+    return () => {
+      cancelled = true;
+    };
+  }, [refetchToken]);
+
+  const refetch = useCallback(() => setRefetchToken((t) => t + 1), []);
+
+  const saveProfile = useCallback(async (patch: ProfileUpdateInput) => {
+    setSaving(true);
+    setError(null);
+    setSaveSuccess(false);
+
+    try {
+      const updated = await profileApi.updateProfile(patch);
+      setState((prev) => ({ ...prev, profile: updated }));
+      // Profile completion (and other snapshot fields) can shift after an edit.
+      profileApi.getCareerSnapshot().then((snapshot) => {
+        setState((prev) => ({ ...prev, snapshot }));
+      });
+      setSaveSuccess(true);
+      setIsEditing(false);
+      setTimeout(() => setSaveSuccess(false), 2500);
+    } catch (err) {
+      setError(err instanceof ApiError ? err.message : "Couldn't save your changes. Please try again.");
+      throw err;
+    } finally {
+      setSaving(false);
+    }
+  }, []);
+
+  return createElement(
+    ProfileContext.Provider,
+    {
+      value: {
+        ...state,
+        loading,
+        error,
+        saving,
+        saveSuccess,
+        isEditing,
+        setIsEditing,
+        refetch,
+        saveProfile,
+      },
+    },
+    children,
+  );
+}
+
+export function useProfile() {
+  const ctx = useContext(ProfileContext);
+  if (!ctx) {
+    throw new Error("useProfile must be used inside <ProfileProvider>");
+  }
+  return ctx;
+}
